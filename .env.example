# 从浏览器 DevTools -> Network -> 任意 panel.fps.ms 请求 -> Request Headers 复制 Cookie
COOKIE=session=...; other=...

# 可选：服务器控制台 URL（默认已内置）
# SERVER_URL=https://panel.fps.ms/server/69f56310-b3db-47b8-b38d-cc1bf7c5a664

# 可选：控制台控制按钮选择器（站点更新后可覆盖）
# CONSOLE_BTN_SELECTOR=#app > div... > button:nth-child(1)

# 可选：有头模式更利于 Turnstile 通过（默认 false）
HEADLESS=false

# 可选：超时毫秒（默认 120000）
# TIMEOUT_MS=120000

# Telegram 通知（可选，两者都填才发送）
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your_chat_id

# GitHub Actions: 将 COOKIE / TELEGRAM_* 等配置为 Repository Secrets
# 手动触发: Actions -> Renew FPS Server -> Run workflow
# 外部触发: POST /repos/{owner}/{repo}/dispatches  event_type=renew-server
